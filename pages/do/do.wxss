.container {
  background-color: #e3f2fd; /* Light blue background */
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #81d4fa;
  margin-bottom: 80rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 0 #e1f5fe;
}

.card-container {
  width: 500rpx;
  height: 600rpx;
  perspective: 2000rpx; /* 3D effect */
  margin-bottom: 80rpx;
}

.card {
  width: 100%;
  height: 100%;
  position: relative;
  transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  transform-style: preserve-3d;
  cursor: pointer;
}

.card.flipped {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 30rpx 60rpx rgba(25, 118, 210, 0.15);
  box-sizing: border-box;
}

.card-front {
  background: linear-gradient(135deg, #b3e5fc, #81d4fa);
  border: 8rpx dashed #e1f5fe;
}

.tap-hint {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.card-back {
  background: #fff;
  border: 8rpx dashed #b3e5fc;
  transform: rotateY(180deg);
  padding: 40rpx;
  flex-direction: column;
}

.do-name {
  font-size: 56rpx;
  font-weight: 900;
  color: #4fc3f7;
  text-align: center;
  line-height: 1.4;
}

.main-btn {
  background: linear-gradient(135deg, #81d4fa, #4fc3f7) !important;
  box-shadow: 0 16rpx 32rpx rgba(129, 212, 250, 0.4) !important;
  opacity: 0;
  animation: fadeInBtn 0.5s forwards 0.3s;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
}

.main-btn:active {
  background: linear-gradient(135deg, #4fc3f7, #29b6f6) !important;
  transform: scale(0.9) skewX(2deg) !important;
}

@keyframes fadeInBtn {
  to { opacity: 1; transform: translateY(0); }
  from { opacity: 0; transform: translateY(20rpx); }
}

.top-bar {
  position: absolute;
  top: calc(40rpx + env(safe-area-inset-top));
  right: 40rpx;
  z-index: 10;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.8);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #1976d2;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(25, 118, 210, 0.1);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.edit-btn:active {
  background: rgba(255, 255, 255, 0.5);
}
