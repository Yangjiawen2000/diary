<view class="diary-container">
  
  <view class="date-header">
    <view class="header-main">
      <text class="date-text">{{todayStr}}</text>
      <view class="history-btn" bindtap="goToHistory">🕰️ 历史日记</view>
    </view>
    <text class="date-greeting">今天也要元气满满哦！</text>
  </view>

  <view class="card luck-card">
    <view class="section-title">✨ 今日幸运色</view>
    <block wx:if="{{luckyColor}}">
      <view class="color-display">
        <view class="color-circle" style="background-color: {{luckyColor.hex}};"></view>
        <text class="color-name" style="color: {{luckyColor.hex}};">{{luckyColor.name}}</text>
      </view>
    </block>
    <block wx:else>
      <button class="draw-btn" bindtap="drawLuckyColor">✨ 点我召唤幸运色 ✨</button>
    </block>
  </view>

  <view class="card summary-card">
    <view class="section-title">🍱 今日足迹</view>
    <view class="summary-line">
      <text class="label">决定吃：</text>
      <text class="value">{{todayFood || '还在发呆中 (´･_･`)'}}</text>
    </view>
    <view class="summary-line">
      <text class="label">决定做：</text>
      <text class="value">{{todayDo || '没有头绪呢 (˘･_･˘)'}}</text>
    </view>
  </view>

  <view class="card editor-card">
    <view class="section-title">
      <text>✍️ 小丸子的日记</text>
      <text class="prompt-btn" bindtap="getDiaryPrompt">✨ 灵感</text>
    </view>

    <!-- Mood Selector -->
    <view class="mood-selector">
      <view 
        wx:for="{{moods}}" 
        wx:key="index" 
        class="mood-item {{selectedMoodIndex === index ? 'active' : ''}}"
        bindtap="selectMood"
        data-index="{{index}}"
      >
        <text class="mood-emoji">{{item.emoji}}</text>
        <text class="mood-label">{{item.label}}</text>
      </view>
    </view>

    <!-- Weather Selector -->
    <view class="weather-selector">
      <view 
        wx:for="{{weathers}}" 
        wx:key="index" 
        class="weather-item {{selectedWeatherIndex === index ? 'active' : ''}}"
        bindtap="selectWeather"
        data-index="{{index}}"
      >
        <text class="weather-emoji">{{item.emoji}}</text>
      </view>
    </view>

    <!-- Location Tag -->
    <view class="location-tag {{!locationName ? 'empty' : ''}}" bindtap="chooseLocationManually">
      <text class="location-icon">📍</text>
      <text class="location-text">{{locationName || '点击手动获取定位'}}</text>
    </view>

    <textarea 
      class="diary-input" 
      placeholder="今天有什么开心的事呀？偷偷告诉我吧 ☁️" 
      value="{{diaryText}}" 
      bindinput="onInput"
      maxlength="500"
    ></textarea>

    <!-- Voice Recording Section -->
    <view class="voice-section">
      <view class="record-btn-container">
        <view class="record-btn {{isRecording ? 'recording' : ''}}" bindtap="toggleRecording">
          <text class="mic-icon">{{isRecording ? '⏹️' : '🎙️'}}</text>
        </view>
        <text class="record-hint">{{isRecording ? '正在记录你的声音...' : '点我录语音'}}</text>
      </view>

      <view class="audio-preview" wx:if="{{tempAudioPath}}">
        <view class="audio-player" bindtap="playTempAudio">
          <text class="play-icon">{{isAudioPlaying ? '⏸️' : '▶️'}}</text>
          <text class="audio-duration">{{audioDuration}}s</text>
        </view>
        <view class="audio-delete" bindtap="clearTempAudio">×</view>
      </view>
    </view>

    <!-- Photo Attachments -->
    <view class="photos-container">
      <block wx:for="{{photos}}" wx:key="index">
        <view class="photo-wrapper">
          <image src="{{item}}" mode="aspectFill" class="diary-photo"></image>
          <view class="delete-badge" bindtap="removePhoto" data-index="{{index}}">×</view>
        </view>
      </block>
      <view class="add-photo-btn" bindtap="chooseImages" wx:if="{{photos.length < 3}}">
        <text class="plus-icon">+</text>
      </view>
    </view>

    <button class="save-btn" bindtap="saveDiary">保存日记</button>
  </view>

</view>
