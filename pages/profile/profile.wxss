.profile-container {
  flex: 1;
  overflow-y: auto;
  background-color: #fffaf0;
  padding: calc(40rpx + env(safe-area-inset-top)) 40rpx calc(160rpx + env(safe-area-inset-bottom)) 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 80rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 10rpx 20rpx rgba(0,0,0,0.1);
  margin-bottom: 30rpx;
  background: #fff;
}

.greeting {
  font-size: 36rpx;
  font-weight: 900;
  color: #ff9a9e;
}

.menu-list {
  background: #fff;
  border-radius: 40rpx;
  padding: 10rpx 0;
  box-shadow: 0 16rpx 40rpx rgba(255, 183, 178, 0.3);
  border: 6rpx dashed #ffd1dc;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:active {
  background: #fafafa;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #c2998d;
  font-weight: bold;
}
