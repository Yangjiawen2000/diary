.container {
  background-color: #fce4ec; /* Light pink background */
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #d81b60;
  margin-bottom: 80rpx;
  letter-spacing: 4rpx;
}

.result-box {
  width: 560rpx;
  height: 360rpx;
  background: #fff;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 30rpx 60rpx rgba(216, 27, 96, 0.15);
  margin-bottom: 80rpx;
  transition: all 0.1s;
  border: 8rpx solid #f8bbd0;
}

.food-name {
  font-size: 72rpx;
  font-weight: 900;
  color: #c2185b;
  text-align: center;
  padding: 0 40rpx;
}

.rolling {
  transform: scale(0.95);
  opacity: 0.8;
  box-shadow: 0 10rpx 20rpx rgba(216, 27, 96, 0.05);
}

.main-btn {
  background: linear-gradient(135deg, #f06292, #d81b60) !important;
  box-shadow: 0 16rpx 32rpx rgba(216, 27, 96, 0.3) !important;
}

.main-btn:active {
  background: linear-gradient(135deg, #e91e63, #c2185b) !important;
}

.hint {
  margin-top: 40rpx;
  font-size: 32rpx;
  color: #880e4f;
  font-weight: 600;
  animation: fadeIn 0.5s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.top-bar {
  position: absolute;
  top: calc(40rpx + env(safe-area-inset-top));
  right: 40rpx;
  z-index: 10;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.8);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #d81b60;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(216, 27, 96, 0.1);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.edit-btn:active {
  background: rgba(255, 255, 255, 0.5);
}
