.container {
  background-color: #fce4ec; /* Light pink background */
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ff9a9e;
  margin-bottom: 80rpx;
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 0 #ffd1dc;
}

.result-box {
  width: 560rpx;
  height: 360rpx;
  background: #fff;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(255, 183, 178, 0.4);
  margin-bottom: 80rpx;
  transition: all 0.1s;
  border: 8rpx dashed #ffd1dc;
}

.food-name {
  font-size: 72rpx;
  font-weight: 900;
  color: #ff9a9e;
  text-align: center;
  padding: 0 40rpx;
}

.rolling {
  transform: scale(0.95);
  opacity: 0.8;
  box-shadow: 0 10rpx 20rpx rgba(255, 154, 158, 0.05);
}

.main-btn {
  background: linear-gradient(135deg, #ffc3a0, #ffb199) !important;
  box-shadow: 0 16rpx 32rpx rgba(255, 177, 153, 0.4) !important;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
}

.main-btn:active {
  background: linear-gradient(135deg, #ffb199, #ff9a9e) !important;
  transform: scale(0.9) skewX(2deg) !important;
}

.hint {
  margin-top: 40rpx;
  font-size: 32rpx;
  color: #880e4f;
  font-weight: 600;
  animation: fadeIn 0.5s ease-in-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.top-bar {
  position: absolute;
  top: calc(40rpx + env(safe-area-inset-top));
  right: 40rpx;
  z-index: 10;
}

.edit-btn {
  background: rgba(255, 255, 255, 0.8);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #d81b60;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(216, 27, 96, 0.1);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.edit-btn:active {
  background: rgba(255, 255, 255, 0.5);
}
