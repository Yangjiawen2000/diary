<view class="history-container">
  
  <view class="calendar-module">
    <view class="cal-header">
      <view class="cal-arrow" bindtap="prevMonth">❮</view>
      <text class="cal-title">{{currYear}}年 {{currMonth}}月</text>
      <view class="cal-arrow" bindtap="nextMonth">❯</view>
    </view>
    <view class="cal-weekdays">
      <text class="cal-wd">日</text><text class="cal-wd">一</text><text class="cal-wd">二</text><text class="cal-wd">三</text><text class="cal-wd">四</text><text class="cal-wd">五</text><text class="cal-wd">六</text>
    </view>
    <view class="cal-grid">
      <view class="cal-cell {{item.type !== 'current' ? 'fade' : ''}} {{item.isSelected ? 'selected' : ''}}" 
            wx:for="{{calendarDays}}" wx:key="dateStr"
            bindtap="selectDate" data-date="{{item.dateStr}}" data-type="{{item.type}}">
        <text class="cal-day">{{item.day}}</text>
        <view class="cal-dot" wx:if="{{item.hasDiary}}"></view>
      </view>
    </view>
  </view>

  <!-- Filter hint -->
  <view class="filter-hint" wx:if="{{selectedDateStr}}">
    <text>正在查看：{{selectedDateStr}}</text>
    <text class="clear-filter" bindtap="selectDate" data-date="{{selectedDateStr}}" data-type="current">取消</text>
  </view>

  <view class="empty-state" wx:if="{{historyList.length === 0}}">
    <text>空空的耶...快去主页写下第一篇日记吧 ( ˶ˆ꒳ˆ˵ )</text>
  </view>
  
  <block wx:for="{{historyList}}" wx:key="date">
    <view class="history-card">
      <view class="card-header">
        <view class="date-time-box">
          <text class="card-date">{{item.date}}</text>
          <text class="card-time" wx:if="{{item.time}}">{{item.time}}</text>
        </view>
        <view class="status-box">
          <text class="card-mood" wx:if="{{item.mood}}">{{item.mood.emoji}}</text>
          <text class="card-weather" wx:if="{{item.weather}}">{{item.weather.emoji}}</text>
        </view>
        <view class="card-color" wx:if="{{item.color}}" style="background-color: {{item.color.hex}};">
          <text style="color: #fff; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);">{{item.color.name}}</text>
        </view>
      </view>
      
      <view class="card-footprint" wx:if="{{item.food || item.doActivity}}">
        <text class="tag" wx:if="{{item.food}}">🍱 {{item.food}}</text>
        <text class="tag" wx:if="{{item.doActivity}}">🏃 {{item.doActivity}}</text>
      </view>
      
      <view class="card-location" wx:if="{{item.location}}">
        <text class="location-icon">📍</text>
        <text class="location-text">{{item.location}}</text>
      </view>

      <view class="card-text" wx:if="{{item.text}}">
        <text>{{item.text}}</text>
      </view>
      <view class="card-text empty-text" wx:else>
        <text>呜呜...今天交了白卷 (╥ω╥)</text>
      </view>

      <view class="history-audio" wx:if="{{item.voicePath}}" bindtap="playHistoryAudio" data-path="{{item.voicePath}}" data-id="{{item.id}}">
        <view class="audio-btn">
          <text class="play-icon">{{playingAudioId === item.id ? '⏸️' : '▶️'}}</text>
        </view>
        <text class="audio-info">语音日记 · {{item.voiceDuration}}s</text>
      </view>

      <view class="history-photos" wx:if="{{item.photos && item.photos.length > 0}}">
        <block wx:for="{{item.photos}}" wx:key="*this" wx:for-item="photo">
          <image class="history-photo" src="{{photo}}" mode="aspectFill"></image>
        </block>
      </view>
    </view>
  </block>
</view>
