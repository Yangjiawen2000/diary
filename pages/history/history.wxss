.history-container {
  flex: 1;
  overflow-y: auto;
  background-color: #fffaf0;
  padding: calc(40rpx + env(safe-area-inset-top)) 40rpx calc(160rpx + env(safe-area-inset-bottom)) 40rpx;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
  color: #a1887f;
  margin-top: 200rpx;
  font-size: 32rpx;
}

.history-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(141, 110, 99, 0.08);
  border: 4rpx solid #ffe0b2;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 2rpx dashed #ffcc80;
  padding-bottom: 20rpx;
}

.card-date {
  font-size: 36rpx;
  font-weight: 900;
  color: #d84315;
}

.card-color {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.card-footprint {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.tag {
  background: #fff3e0;
  color: #d84315;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.card-text {
  font-size: 30rpx;
  color: #4e342e;
  line-height: 1.6;
  white-space: pre-wrap;
  background: #fdfaf6;
  padding: 20rpx;
  border-radius: 16rpx;
}

.empty-text {
  color: #bcaaa4;
  font-style: italic;
  background: transparent;
}

.card-location {
  display: inline-flex;
  align-items: center;
  background: #e3f2fd;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
}

.card-location .location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.card-location .location-text {
  font-size: 24rpx;
  color: #1565c0;
  font-weight: bold;
}

.history-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.history-photo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  border: 2rpx solid #eee;
}
