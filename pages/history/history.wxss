.history-container {
  flex: 1;
  overflow-y: auto;
  background-color: #fffaf0;
  padding: calc(40rpx + env(safe-area-inset-top)) 40rpx calc(160rpx + env(safe-area-inset-bottom)) 40rpx;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
  color: #a1887f;
  margin-top: 100rpx;
  font-size: 32rpx;
}

/* Calendar Styles */
.calendar-module {
  background: #fff;
  border-radius: 40rpx;
  padding: 30rpx 40rpx 40rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(255, 183, 178, 0.3);
  border: 6rpx dashed #ffd1dc;
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.cal-arrow {
  padding: 10rpx 30rpx;
  color: #ff9a9e;
  font-size: 36rpx;
  font-weight: 900;
  border-radius: 20rpx;
  background: #fff0f5;
  box-shadow: 0 4rpx 10rpx rgba(255, 183, 178, 0.2);
}
.cal-arrow:active {
  transform: scale(0.9) skewX(2deg);
}

.cal-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #ff9a9e;
}

.cal-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.cal-wd {
  font-size: 28rpx;
  color: #c2998d;
  font-weight: bold;
  width: 14.28%;
  text-align: center;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-cell {
  width: 14.28%;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 24rpx;
  transition: all 0.2s;
  background: transparent;
}

.cal-cell.fade {
  opacity: 0.3;
}

.cal-day {
  font-size: 32rpx;
  color: #5d4037;
  font-weight: bold;
}

.cal-dot {
  width: 10rpx;
  height: 10rpx;
  background-color: #ff9a9e;
  border-radius: 50%;
  position: absolute;
  bottom: 8rpx;
}

.cal-cell.selected {
  background: #ff9a9e;
  transform: scale(1.05);
  box-shadow: 0 6rpx 16rpx rgba(255, 154, 158, 0.4);
}

.cal-cell.selected .cal-day {
  color: #fff;
}

.cal-cell.selected .cal-dot {
  background-color: #fff;
}

.filter-hint {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff0f5;
  padding: 16rpx 30rpx;
  border-radius: 40rpx;
  margin-bottom: 40rpx;
  font-size: 28rpx;
  color: #ff9a9e;
  font-weight: bold;
}

.clear-filter {
  background: white;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  color: #c2998d;
  font-size: 24rpx;
}



.history-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 40rpx rgba(255, 183, 178, 0.3);
  border: 6rpx dashed #ffd1dc;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  border-bottom: 2rpx dashed #ffcc80;
  padding-bottom: 20rpx;
}

.date-time-box {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.card-date {
  font-size: 36rpx;
  font-weight: 900;
  color: #ff9a9e;
}

.card-time {
  font-size: 28rpx;
  color: #c2998d;
  font-weight: bold;
}

.status-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: auto;
  margin-right: 20rpx;
}

.card-mood, .card-weather {
  font-size: 40rpx;
}

.card-color {
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.card-footprint {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.tag {
  background: #fff0f5;
  color: #ff9a9e;
  padding: 10rpx 24rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.card-text {
  font-size: 30rpx;
  color: #c2998d;
  line-height: 1.6;
  white-space: pre-wrap;
  background: #fdfaf6;
  padding: 24rpx;
  border-radius: 20rpx;
}

.empty-text {
  color: #bcaaa4;
  font-style: italic;
  background: transparent;
}

.card-location {
  display: inline-flex;
  align-items: center;
  background: #fff0f5;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-bottom: 24rpx;
}

.card-location .location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.card-location .location-text {
  font-size: 24rpx;
  color: #ff9a9e;
  font-weight: bold;
}

.history-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.history-photo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  border: 2rpx solid #eee;
}

.history-audio {
  background: #fff0f5;
  margin-top: 24rpx;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 2rpx solid #ffd1dc;
  transition: all 0.2s ease;
}

.history-audio:active {
  transform: scale(0.98);
  background: #ffe4e8;
}

.audio-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(255, 183, 178, 0.3);
}

.audio-btn .play-icon {
  font-size: 28rpx;
  color: #ff9a9e;
}

.audio-info {
  font-size: 26rpx;
  color: #c2998d;
  font-weight: bold;
}
