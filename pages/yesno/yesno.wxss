.container {
  background-color: #f5f5f5; /* Light gray background */
}

.title {
  font-size: 64rpx;
  font-weight: 900;
  color: #212121;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #757575;
  margin-bottom: 120rpx;
}

.coin-container {
  width: 400rpx;
  height: 400rpx;
  perspective: 2000rpx;
  margin-bottom: 80rpx;
}

.coin {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  cursor: pointer;
  transition: transform 0.1s;
}

/* Base starting position */
.coin.show-yes { transform: rotateX(0deg); }
.coin.show-no { transform: rotateX(180deg); }

/* Animation class */
.coin.flipping {
  animation: flipAnimation 1.5s cubic-bezier(0.3, 0.1, 0.4, 1) forwards;
}

/* In the JS, we dynamically change the animation target 
   but for CSS simplicity, we can just spin it rapidly and the transition
   will snap it to show-yes/show-no after animation finishes 
   We will use inline styles in JS for the dynamic spin, or let CSS handle a generic spin */
@keyframes flipAnimation {
  0% { transform: rotateX(0deg) translateY(0); }
  50% { transform: rotateX(1080deg) translateY(-300rpx); } /* 3 spins up */
  100% { transform: rotateX(2160deg) translateY(0); } /* Will snap to result via JS classes */
}

.coin-face {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 40rpx rgba(0,0,0,0.1), 0 20rpx 40rpx rgba(0,0,0,0.2);
  border: 16rpx solid #fff;
  box-sizing: border-box;
}

.coin-front {
  background: linear-gradient(135deg, #ffd54f, #ff8f00);
  border-color: #ffca28;
}

.coin-back {
  background: linear-gradient(135deg, #e0e0e0, #9e9e9e);
  border-color: #bdbdbd;
  transform: rotateX(180deg);
}

.coin-text {
  font-size: 80rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3);
}

.result-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #424242;
  animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes popIn {
  from { opacity: 0; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1); }
}
