/**app.wxss**/
page {
  background-color: #fffaf0;
  font-family: 'PingFang SC', 'Microsoft Yahei', sans-serif;
  color: #c2998d;
}

/* Base cute bouncy button */
.btn-bouncy {
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}
.btn-bouncy:active {
  transform: scale(0.9) skewX(2deg) !important;
}

/* Soft shadows */
.shadow-soft {
  box-shadow: 0 16rpx 40rpx rgba(255, 183, 178, 0.3) !important;
}

/* Cute cards */
.card-cute {
  background: #fff;
  border-radius: 40rpx !important;
  border: 6rpx dashed #ffd1dc !important;
}
.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: calc(40rpx + env(safe-area-inset-top)) 40rpx calc(140rpx + env(safe-area-inset-bottom)) 40rpx;
  box-sizing: border-box;
  position: relative;
}

.main-btn {
  margin-top: 80rpx;
  width: 80% !important;
  border-radius: 100rpx;
  background: #000;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.15);
  transition: all 0.2s ease;
  padding: 24rpx 0;
}

.main-btn:active {
  transform: scale(0.96);
  background: #333;
}

/* Mood Selector Styles */
.mood-selector {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0;
  padding: 10rpx 0;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s ease;
  padding: 10rpx;
  border-radius: 20rpx;
}

.mood-item.active {
  background: rgba(255, 183, 178, 0.2);
  transform: scale(1.1);
}

.mood-emoji {
  font-size: 50rpx;
  margin-bottom: 4rpx;
}

.mood-label {
  font-size: 20rpx;
  color: #c2998d;
}

/* Weather Selector Styles */
.weather-selector {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.weather-item {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 50%;
  border: 4rpx solid #fff0f5;
  transition: all 0.2s ease;
  font-size: 36rpx;
}

.weather-item.active {
  border-color: #ff9a9e;
  background: #fff0f5;
  transform: scale(1.1);
}
